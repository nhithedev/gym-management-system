NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# Supabase Transaction pooler (IPv4), port 6543.
# URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-X-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1&pool_timeout=20&connect_timeout=20

# Prisma DDL: prefer the direct connection. If IPv6/direct access is unavailable,
# use the same Session pooler URL as above without the runtime pool parameters.
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ExerciseDB API (RapidAPI) - dung cho script fetch exercises
# Dang ky tai: https://rapidapi.com, search exercisedb, subscribe va lay API key
EXERCISEDB_API_KEY=

# DEMO ONLY - master OTP luon qua de demo deploy khi chua co SMTP that.
# Bo trong hoac xoa dong nay de tat (logic OTP that giu nguyen).
# TUYET DOI khong set o production that.
DEMO_MASTER_OTP=111111
