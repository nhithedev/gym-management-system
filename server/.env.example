NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# Persistent NestJS runtime: Supabase Session pooler (IPv4), port 5432.
# URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-X-<region>.pooler.supabase.com:5432/postgres?sslmode=require&connection_limit=5&pool_timeout=10&connect_timeout=15

# Prisma DDL: prefer the direct connection. If IPv6/direct access is unavailable,
# use the same Session pooler URL as above without the runtime pool parameters.
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
