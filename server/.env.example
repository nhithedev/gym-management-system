# Runtime
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
# prisma/schema.prisma: url = DATABASE_URL, directUrl = DIRECT_URL (ca hai can co khi chay prisma generate / migrate).

# ------------------------------------------------------------
# Local (khong Supavisor)
# ------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gym_management?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/gym_management?schema=public

# ------------------------------------------------------------
# Supabase (PostgreSQL trong dashboard: Project Settings > Database)
#
# DATABASE_URL — Transaction pooler (cong ~6543, Supavisor) cho Prisma Client / runtime Nest.
#   - Trong Dashboard: muc "Transaction pooler" hoac URI co pooler.supabase.com:6543
#   - Luon them: ?pgbouncer=true (& sslmode=require neu can)
# DIRECT_URL — ket noi truc tiep (khong pooling) cho Prisma CLI migrate / drift.
#   - Uu tien muc "Direct connection": host db.<PROJECT_REF>.supabase.co port 5432
#     (user thuong la postgres:<password>; hoac dong Session pooler :5432 tren pooler host)
#
# LUU Y:
# - Mat khau trong URL phai encode (vd @ -> %40, # -> %23).
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Auth (JWT) — JWT rieng cua Nest, khong dung JWT Supabase Auth (chi chung Postgres public schema).
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Mail (SMTP) - optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

DEVICE_API_KEY=

# LINE LIFF (optional -- chi can khi bat LINE login)
LINE_CHANNEL_ID=your_line_channel_id_here
