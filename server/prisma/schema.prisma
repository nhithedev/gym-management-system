// =============================================================================
// Gym Management System - Prisma schema
// Khop voi docs/Design/Database.md va migration SQL goc.
// 19 model + 11 enum. Tat ca dung snake_case o tang DB qua @map / @@map.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// ENUM TYPES (map sang Postgres ENUM type co san trong DB)
// -----------------------------------------------------------------------------

enum UserStatus {
  active
  locked

  @@map("user_status")
}

enum PackageStatus {
  active
  inactive

  @@map("package_status")
}

enum PaymentMethod {
  cash
  bank_card
  ewallet

  @@map("payment_method")
}

enum PaymentStatus {
  success
  failed

  @@map("payment_status")
}

enum EquipmentStatus {
  active
  broken
  repairing
  retired

  @@map("equipment_status")
}

enum MaintenanceStatus {
  reported
  repairing
  resolved
  failed

  @@map("maintenance_status")
}

enum FeedbackType {
  staff
  equipment
  service

  @@map("feedback_type")
}

enum FeedbackSeverity {
  low
  medium
  high

  @@map("feedback_severity")
}

enum FeedbackStatus {
  open
  in_progress
  resolved

  @@map("feedback_status")
}

enum AttendanceMethod {
  realtime
  manual
  qr

  @@map("attendance_method")
}

enum StaffShift {
  morning
  afternoon
  evening

  @@map("staff_shift")
}

// -----------------------------------------------------------------------------
// 1) TAI KHOAN
// -----------------------------------------------------------------------------

model User {
  userId       BigInt     @id @default(autoincrement()) @map("user_id")
  email        String     @unique @db.VarChar(255)
  phone        String?    @unique @db.VarChar(20)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  fullName     String     @map("full_name") @db.VarChar(200)
  status       UserStatus
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamp(6)

  member        Member?
  staff         Staff?
  notifications Notification[]
  groups        UserGroup[]
  otpCodes      OtpCode[]

  @@map("users")
}

model Member {
  memberId    BigInt   @id @default(autoincrement()) @map("member_id")
  userId      BigInt   @unique @map("user_id")
  memberCode  String   @unique @map("member_code") @db.VarChar(30)
  dateOfBirth DateTime @map("date_of_birth") @db.Date
  address     String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user             User              @relation(fields: [userId], references: [userId])
  subscriptions    Subscription[]
  payments         Payment[]
  trainingSessions TrainingSession[]
  attendanceLogs   AttendanceLog[]
  progressRecords  MemberProgress[]
  feedback         Feedback[]

  @@map("members")
}

model Staff {
  staffId   BigInt @id @default(autoincrement()) @map("staff_id")
  userId    BigInt @unique @map("user_id")
  staffCode String @unique @map("staff_code") @db.VarChar(30)
  position  String @db.VarChar(50)

  user               User              @relation(fields: [userId], references: [userId])
  maintenanceLogs    MaintenanceLog[]
  trainingSessions   TrainingSession[]
  memberProgresses   MemberProgress[]
  handledFeedback    Feedback[]        @relation("FeedbackHandledBy")
  feedbackAboutStaff Feedback[]        @relation("FeedbackSubjectStaff")
  schedules          StaffSchedule[]

  @@map("staff")
}

// -----------------------------------------------------------------------------
// 2) PHAN QUYEN (Group-Based Access Control)
// -----------------------------------------------------------------------------

model Group {
  groupId     BigInt  @id @default(autoincrement()) @map("group_id")
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(255)

  users       UserGroup[]
  permissions GroupPermission[]

  @@map("groups")
}

model Permission {
  permissionId BigInt  @id @default(autoincrement()) @map("permission_id")
  code         String  @unique @db.VarChar(50)
  name         String  @db.VarChar(100)
  description  String? @db.VarChar(255)

  groups GroupPermission[]

  @@map("permissions")
}

model UserGroup {
  userId  BigInt @map("user_id")
  groupId BigInt @map("group_id")

  user  User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("user_groups")
}

model GroupPermission {
  groupId      BigInt @map("group_id")
  permissionId BigInt @map("permission_id")

  group      Group      @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade)

  @@id([groupId, permissionId])
  @@map("group_permissions")
}

// -----------------------------------------------------------------------------
// 3) GOI TAP & THANH TOAN
// -----------------------------------------------------------------------------

model Package {
  packageId    BigInt        @id @default(autoincrement()) @map("package_id")
  packageCode  String        @unique @map("package_code") @db.VarChar(30)
  name         String        @db.VarChar(100)
  durationDays Int           @map("duration_days")
  sessionLimit Int           @map("session_limit")
  price        Decimal       @db.Decimal(12, 2)
  benefits     String?       @db.VarChar(255)
  status       PackageStatus
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  subscriptions Subscription[]

  @@map("packages")
}

model Subscription {
  subscriptionId    BigInt   @id @default(autoincrement()) @map("subscription_id")
  memberId          BigInt   @map("member_id")
  packageId         BigInt   @map("package_id")
  startDate         DateTime @map("start_date") @db.Date
  endDate           DateTime @map("end_date") @db.Date
  remainingSessions Int      @map("remaining_sessions")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  member         Member          @relation(fields: [memberId], references: [memberId])
  package        Package         @relation(fields: [packageId], references: [packageId])
  payments       Payment[]
  attendanceLogs AttendanceLog[]

  @@map("subscriptions")
}

model Payment {
  paymentId            BigInt        @id @default(autoincrement()) @map("payment_id")
  memberId             BigInt        @map("member_id")
  subscriptionId       BigInt        @map("subscription_id")
  amount               Decimal       @db.Decimal(12, 2)
  method               PaymentMethod
  status               PaymentStatus
  transactionReference String?       @map("transaction_reference") @db.VarChar(100)
  paidAt               DateTime      @map("paid_at") @db.Timestamp(6)

  member       Member       @relation(fields: [memberId], references: [memberId])
  subscription Subscription @relation(fields: [subscriptionId], references: [subscriptionId])

  @@map("payments")
}

// -----------------------------------------------------------------------------
// 4) CO SO VAT CHAT
// -----------------------------------------------------------------------------

model GymRoom {
  roomId      BigInt  @id @default(autoincrement()) @map("room_id")
  roomCode    String  @unique @map("room_code") @db.VarChar(30)
  name        String  @db.VarChar(100)
  roomType    String? @map("room_type") @db.VarChar(50)
  capacity    Int
  description String? @db.VarChar(255)

  equipment        Equipment[]
  trainingSessions TrainingSession[]

  @@map("gym_rooms")
}

model Equipment {
  equipmentId   BigInt          @id @default(autoincrement()) @map("equipment_id")
  roomId        BigInt          @map("room_id")
  equipmentCode String          @unique @map("equipment_code") @db.VarChar(30)
  name          String          @db.VarChar(100)
  importDate    DateTime        @map("import_date") @db.Date
  warrantyUntil DateTime?       @map("warranty_until") @db.Date
  status        EquipmentStatus

  room              GymRoom          @relation(fields: [roomId], references: [roomId])
  maintenanceLogs   MaintenanceLog[]
  feedbackAboutThis Feedback[]       @relation("FeedbackSubjectEquipment")

  @@map("equipment")
}

model MaintenanceLog {
  maintenanceId      BigInt            @id @default(autoincrement()) @map("maintenance_id")
  equipmentId        BigInt            @map("equipment_id")
  reportedByStaffId  BigInt            @map("reported_by_staff_id")
  description       String            @db.Text
  status            MaintenanceStatus
  reportedAt        DateTime          @map("reported_at") @db.Timestamp(6)
  resolvedAt        DateTime?         @map("resolved_at") @db.Timestamp(6)

  equipment       Equipment @relation(fields: [equipmentId], references: [equipmentId])
  reportedByStaff Staff     @relation(fields: [reportedByStaffId], references: [staffId])

  @@map("maintenance_logs")
}

// -----------------------------------------------------------------------------
// 5) LICH TAP & GHI NHAN
// -----------------------------------------------------------------------------

model TrainingSession {
  sessionId      BigInt   @id @default(autoincrement()) @map("session_id")
  memberId       BigInt   @map("member_id")
  trainerStaffId BigInt   @map("trainer_staff_id")
  roomId         BigInt   @map("room_id")
  startTime      DateTime @map("start_time") @db.Timestamp(6)
  endTime        DateTime @map("end_time") @db.Timestamp(6)

  member         Member          @relation(fields: [memberId], references: [memberId])
  trainer        Staff           @relation(fields: [trainerStaffId], references: [staffId])
  room           GymRoom         @relation(fields: [roomId], references: [roomId])
  attendanceLogs AttendanceLog[]

  @@map("training_sessions")
}

model AttendanceLog {
  attendanceId   BigInt            @id @default(autoincrement()) @map("attendance_id")
  memberId       BigInt            @map("member_id")
  subscriptionId BigInt            @map("subscription_id")
  sessionId      BigInt?           @map("session_id")
  startTime      DateTime          @map("start_time") @db.Timestamp(6)
  endTime        DateTime?         @map("end_time") @db.Timestamp(6)
  method         AttendanceMethod?

  member       Member           @relation(fields: [memberId], references: [memberId])
  subscription Subscription     @relation(fields: [subscriptionId], references: [subscriptionId])
  session      TrainingSession? @relation(fields: [sessionId], references: [sessionId])

  @@map("attendance_logs")
}

model MemberProgress {
  progressId BigInt   @id @default(autoincrement()) @map("progress_id")
  memberId   BigInt   @map("member_id")
  staffId    BigInt   @map("staff_id")
  weight     Decimal? @db.Decimal(6, 2)
  bmi        Decimal? @db.Decimal(5, 2)
  goal       String?  @db.VarChar(255)
  notes      String?  @db.Text
  recordedAt DateTime @map("recorded_at") @db.Timestamp(6)

  member Member @relation(fields: [memberId], references: [memberId])
  staff  Staff  @relation(fields: [staffId], references: [staffId])

  @@map("member_progress")
}

// -----------------------------------------------------------------------------
// 6) KHAC: phan hoi, thong bao, lich lam viec
// -----------------------------------------------------------------------------

model Feedback {
  feedbackId         BigInt            @id @default(autoincrement()) @map("feedback_id")
  memberId           BigInt            @map("member_id")
  feedbackType       FeedbackType      @map("feedback_type")
  content            String            @db.Text
  severity           FeedbackSeverity?
  status             FeedbackStatus?
  handledByStaffId   BigInt?           @map("handled_by_staff_id")
  handledAt          DateTime?         @map("handled_at") @db.Timestamp(6)
  subjectStaffId     BigInt?           @map("subject_staff_id")
  subjectEquipmentId BigInt?           @map("subject_equipment_id")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamp(6)

  // CHECK constraint chk_feedback_subject duoc them o migration rieng:
  //   - feedback_type='staff'     => subject_staff_id NOT NULL, subject_equipment_id NULL
  //   - feedback_type='equipment' => subject_equipment_id NOT NULL, subject_staff_id NULL
  //   - feedback_type='service'   => ca hai NULL

  member           Member     @relation(fields: [memberId], references: [memberId])
  handledByStaff   Staff?     @relation("FeedbackHandledBy", fields: [handledByStaffId], references: [staffId])
  subjectStaff     Staff?     @relation("FeedbackSubjectStaff", fields: [subjectStaffId], references: [staffId])
  subjectEquipment Equipment? @relation("FeedbackSubjectEquipment", fields: [subjectEquipmentId], references: [equipmentId])

  @@map("feedback")
}

model Notification {
  notificationId BigInt   @id @default(autoincrement()) @map("notification_id")
  userId         BigInt   @map("user_id")
  title          String   @db.VarChar(200)
  content        String   @db.Text
  sentAt         DateTime @map("sent_at") @db.Timestamp(6)
  isRead         Boolean  @default(false) @map("is_read")

  user User @relation(fields: [userId], references: [userId])

  @@map("notifications")
}

model StaffSchedule {
  scheduleId BigInt     @id @default(autoincrement()) @map("schedule_id")
  staffId    BigInt     @map("staff_id")
  shift      StaffShift
  workDate   DateTime   @map("work_date") @db.Date

  staff Staff @relation(fields: [staffId], references: [staffId])

  @@map("staff_schedules")
}

// UC02 - Ma OTP dat lai mat khau (6 chu so, het han sau 10 phut).
model OtpCode {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  codeHash  String   @map("code_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("otp_codes")
}
