generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  userId          BigInt      @id @default(autoincrement()) @map("user_id")
  email           String      @unique @db.VarChar(255)
  phone           String?     @unique @db.VarChar(20)
  passwordHash    String?     @map("password_hash") @db.VarChar(255)
  fullName        String      @map("full_name") @db.VarChar(200)
  status          UserStatus  @default(pending_verification)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  avatarFileId    BigInt?     @map("avatar_file_id")
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamp(6)
  emailVerifiedAt DateTime?   @map("email_verified_at") @db.Timestamp(6)
  lineId          String?     @unique @map("line_id") @db.VarChar(50)
  auditLogs       AuditLog[]
  ownedFiles      File[]      @relation("FileOwner")
  member          Member?
  staff           Staff?
  groups          UserGroup[]
  avatarFile      File?       @relation("UserAvatar", fields: [avatarFileId], references: [fileId])

  @@map("users")
}

model Member {
  memberId            BigInt              @id @default(autoincrement()) @map("member_id")
  userId              BigInt              @unique @map("user_id")
  memberCode          String              @unique @map("member_code") @db.VarChar(30)
  dateOfBirth         DateTime?           @map("date_of_birth") @db.Date
  address             String?             @db.VarChar(200)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt           DateTime?           @map("deleted_at") @db.Timestamp(6)
  primaryTrainerId    BigInt?             @map("primary_trainer_id")
  attendanceLogs      AttendanceLog[]
  feedback            Feedback[]
  progressRecords     MemberProgress[]
  workoutAssignments  MemberWorkoutPlan[]
  primaryTrainer      Staff?              @relation("MemberPrimaryTrainer", fields: [primaryTrainerId], references: [staffId])
  user                User                @relation(fields: [userId], references: [userId])
  paymentAccounts     PaymentAccount[]
  payments            Payment[]
  subscriptions       Subscription[]
  trainingSessions    TrainingSession[]
  workoutLogs         WorkoutLog[]
  createdWorkoutPlans WorkoutPlan[]       @relation("MemberCreatedPlans")

  @@index([createdAt(sort: Desc)])
  @@map("members")
}

model Staff {
  staffId              BigInt              @id @default(autoincrement()) @map("staff_id")
  userId               BigInt              @unique @map("user_id")
  staffCode            String              @unique @map("staff_code") @db.VarChar(30)
  position             String              @db.VarChar(50)
  deletedAt            DateTime?           @map("deleted_at") @db.Timestamp(6)
  createdExercises     Exercise[]
  handledFeedback      Feedback[]          @relation("FeedbackHandledBy")
  feedbackAboutStaff   Feedback[]          @relation("FeedbackSubjectStaff")
  maintenanceLogs      MaintenanceLog[]
  memberProgresses     MemberProgress[]
  assignedWorkoutPlans MemberWorkoutPlan[]
  primaryForMembers    Member[]            @relation("MemberPrimaryTrainer")
  user                 User                @relation(fields: [userId], references: [userId])
  schedules            StaffSchedule[]
  trainingSessions     TrainingSession[]
  createdWorkoutPlans  WorkoutPlan[]
  managedSubscriptions Subscription[]      @relation("SubscriptionTrainer")

  @@map("staff")
}

model Group {
  groupId     BigInt            @id @default(autoincrement()) @map("group_id")
  name        String            @unique @db.VarChar(100)
  description String?           @db.VarChar(255)
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamp(6)
  permissions GroupPermission[]
  users       UserGroup[]

  @@map("groups")
}

model Permission {
  permissionId BigInt            @id @default(autoincrement()) @map("permission_id")
  code         String            @unique @db.VarChar(50)
  name         String            @db.VarChar(100)
  description  String?           @db.VarChar(255)
  groups       GroupPermission[]

  @@map("permissions")
}

model UserGroup {
  userId  BigInt @map("user_id")
  groupId BigInt @map("group_id")
  group   Group  @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("user_groups")
}

model GroupPermission {
  groupId      BigInt     @map("group_id")
  permissionId BigInt     @map("permission_id")
  group        Group      @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade)

  @@id([groupId, permissionId])
  @@map("group_permissions")
}

model Package {
  packageId     BigInt         @id @default(autoincrement()) @map("package_id")
  packageCode   String         @unique @map("package_code") @db.VarChar(30)
  name          String         @db.VarChar(100)
  durationDays  Int            @map("duration_days")
  price         Decimal        @db.Decimal(12, 2)
  benefits      String?        @db.VarChar(255)
  includesPt    Boolean        @default(false) @map("includes_pt")
  status        PackageStatus  @default(active)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamp(6)
  subscriptions Subscription[]

  @@map("packages")
}

model Subscription {
  subscriptionId BigInt             @id @default(autoincrement()) @map("subscription_id")
  memberId       BigInt             @map("member_id")
  packageId      BigInt             @map("package_id")
  trainerId      BigInt?            @map("trainer_id")
  startDate      DateTime           @map("start_date") @db.Date
  endDate        DateTime           @map("end_date") @db.Date
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  cancelledAt    DateTime?          @map("cancelled_at") @db.Timestamp(6)
  deletedAt      DateTime?          @map("deleted_at") @db.Timestamp(6)
  status         SubscriptionStatus @default(pending)
  attendanceLogs AttendanceLog[]
  payments       Payment[]
  member         Member             @relation(fields: [memberId], references: [memberId])
  package        Package            @relation(fields: [packageId], references: [packageId])
  trainer        Staff?             @relation("SubscriptionTrainer", fields: [trainerId], references: [staffId])

  @@index([memberId, status])
  @@index([packageId, status])
  @@index([trainerId, status])
  @@map("subscriptions")
}

model Payment {
  paymentId            BigInt        @id @default(autoincrement()) @map("payment_id")
  memberId             BigInt        @map("member_id")
  subscriptionId       BigInt        @map("subscription_id")
  amount               Decimal       @db.Decimal(12, 2)
  method               PaymentMethod
  status               PaymentStatus
  transactionReference String?       @unique @map("transaction_reference") @db.VarChar(100)
  paidAt               DateTime      @map("paid_at") @db.Timestamp(6)
  member               Member        @relation(fields: [memberId], references: [memberId])
  subscription         Subscription  @relation(fields: [subscriptionId], references: [subscriptionId])

  @@index([memberId, paidAt(sort: Desc)])
  @@index([subscriptionId])
  @@index([status, paidAt(sort: Desc)])
  @@map("payments")
}

model PaymentAccount {
  accountId  Int           @id @default(autoincrement()) @map("account_id")
  memberId   BigInt        @map("member_id")
  type       PaymentMethod
  provider   String?       @db.VarChar(100)
  accountRef String?       @map("account_ref") @db.VarChar(100)
  label      String?       @db.VarChar(100)
  isDefault  Boolean       @default(false) @map("is_default")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt  DateTime?     @map("deleted_at") @db.Timestamp(6)
  member     Member        @relation(fields: [memberId], references: [memberId])

  @@index([memberId])
  @@map("payment_accounts")
}

model GymRoom {
  roomId           BigInt            @id @default(autoincrement()) @map("room_id")
  roomCode         String            @unique @map("room_code") @db.VarChar(30)
  name             String            @db.VarChar(100)
  roomType         String?           @map("room_type") @db.VarChar(50)
  capacity         Int
  description      String?           @db.VarChar(255)
  equipment        Equipment[]
  trainingSessions TrainingSession[]

  @@map("gym_rooms")
}

model Equipment {
  equipmentId       BigInt           @id @default(autoincrement()) @map("equipment_id")
  roomId            BigInt           @map("room_id")
  equipmentCode     String           @unique @map("equipment_code") @db.VarChar(30)
  name              String           @db.VarChar(100)
  importDate        DateTime         @map("import_date") @db.Date
  warrantyUntil     DateTime?        @map("warranty_until") @db.Date
  status            EquipmentStatus
  room              GymRoom          @relation(fields: [roomId], references: [roomId])
  feedbackAboutThis Feedback[]       @relation("FeedbackSubjectEquipment")
  maintenanceLogs   MaintenanceLog[]

  @@map("equipment")
}

model MaintenanceLog {
  maintenanceId     BigInt            @id @default(autoincrement()) @map("maintenance_id")
  equipmentId       BigInt            @map("equipment_id")
  reportedByStaffId BigInt            @map("reported_by_staff_id")
  description       String
  status            MaintenanceStatus
  reportedAt        DateTime          @map("reported_at") @db.Timestamp(6)
  resolvedAt        DateTime?         @map("resolved_at") @db.Timestamp(6)
  equipment         Equipment         @relation(fields: [equipmentId], references: [equipmentId])
  reportedByStaff   Staff             @relation(fields: [reportedByStaffId], references: [staffId])

  @@map("maintenance_logs")
}

model TrainingSession {
  sessionId      BigInt                @id @default(autoincrement()) @map("session_id")
  memberId       BigInt                @map("member_id")
  trainerStaffId BigInt                @map("trainer_staff_id")
  roomId         BigInt                @map("room_id")
  startTime      DateTime              @map("start_time") @db.Timestamp(6)
  endTime        DateTime              @map("end_time") @db.Timestamp(6)
  deletedAt      DateTime?             @map("deleted_at") @db.Timestamp(6)
  status         TrainingSessionStatus @default(scheduled)
  attendanceLogs AttendanceLog[]
  member         Member                @relation(fields: [memberId], references: [memberId])
  room           GymRoom               @relation(fields: [roomId], references: [roomId])
  trainer        Staff                 @relation(fields: [trainerStaffId], references: [staffId])

  @@index([trainerStaffId, startTime(sort: Desc)])
  @@map("training_sessions")
}

model AttendanceLog {
  attendanceId   BigInt           @id @default(autoincrement()) @map("attendance_id")
  memberId       BigInt           @map("member_id")
  subscriptionId BigInt           @map("subscription_id")
  sessionId      BigInt?          @map("session_id")
  startTime      DateTime         @map("start_time") @db.Timestamp(6)
  endTime        DateTime?        @map("end_time") @db.Timestamp(6)
  method         AttendanceMethod
  member         Member           @relation(fields: [memberId], references: [memberId])
  session        TrainingSession? @relation(fields: [sessionId], references: [sessionId])
  subscription   Subscription     @relation(fields: [subscriptionId], references: [subscriptionId])

  @@index([memberId, startTime(sort: Desc)])
  @@index([subscriptionId])
  @@index([sessionId])
  @@map("attendance_logs")
}

model MemberProgress {
  progressId BigInt    @id @default(autoincrement()) @map("progress_id")
  memberId   BigInt    @map("member_id")
  staffId    BigInt?   @map("staff_id")
  weight     Decimal?  @db.Decimal(6, 2)
  height     Decimal?  @db.Decimal(5, 1) @map("height")
  bmi        Decimal?  @db.Decimal(5, 2)
  goal       String?   @db.VarChar(255)
  notes      String?
  recordedAt DateTime  @map("recorded_at") @db.Timestamp(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(6)
  member     Member    @relation(fields: [memberId], references: [memberId])
  staff      Staff?    @relation(fields: [staffId], references: [staffId])

  @@map("member_progress")
}

model Feedback {
  feedbackId         BigInt           @id @default(autoincrement()) @map("feedback_id")
  memberId           BigInt           @map("member_id")
  feedbackType       FeedbackType     @map("feedback_type")
  content            String
  severity           FeedbackSeverity @default(low)
  status             FeedbackStatus   @default(open)
  handledByStaffId   BigInt?          @map("handled_by_staff_id")
  handledAt          DateTime?        @map("handled_at") @db.Timestamp(6)
  subjectStaffId     BigInt?          @map("subject_staff_id")
  subjectEquipmentId BigInt?          @map("subject_equipment_id")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt          DateTime?        @map("deleted_at") @db.Timestamp(6)
  handledByStaff     Staff?           @relation("FeedbackHandledBy", fields: [handledByStaffId], references: [staffId])
  member             Member           @relation(fields: [memberId], references: [memberId])
  subjectEquipment   Equipment?       @relation("FeedbackSubjectEquipment", fields: [subjectEquipmentId], references: [equipmentId])
  subjectStaff       Staff?           @relation("FeedbackSubjectStaff", fields: [subjectStaffId], references: [staffId])

  @@index([status, severity, createdAt(sort: Desc)])
  @@index([memberId, createdAt(sort: Desc)])
  @@index([subjectStaffId, createdAt(sort: Desc)])
  @@map("feedback")
}

model StaffSchedule {
  scheduleId BigInt     @id @default(autoincrement()) @map("schedule_id")
  staffId    BigInt     @map("staff_id")
  shift      StaffShift
  workDate   DateTime   @map("work_date") @db.Date
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamp(6)
  staff      Staff      @relation(fields: [staffId], references: [staffId])

  @@index([staffId])
  @@index([workDate, shift])
  @@map("staff_schedules")
}

model AuditLog {
  auditId      BigInt   @id @default(autoincrement()) @map("audit_id")
  actorUserId  BigInt?  @map("actor_user_id")
  action       String   @db.VarChar(100)
  resourceType String   @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.VarChar(50)
  beforeData   Json?    @map("before_data")
  afterData    Json?    @map("after_data")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  actor        User?    @relation(fields: [actorUserId], references: [userId])

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Exercise {
  exerciseId       BigInt                @id @default(autoincrement()) @map("exercise_id")
  name             String                @db.VarChar(100)
  category         ExerciseCategory
  muscleGroup      String?               @map("muscle_group") @db.VarChar(100)
  equipmentNeeded  String?               @map("equipment_needed") @db.VarChar(100)
  description      String?
  createdByStaffId BigInt?               @map("created_by_staff_id")
  deletedAt        DateTime?             @map("deleted_at") @db.Timestamp(6)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamp(6)
  imageUrl         String?               @map("image_url") @db.VarChar(1000)
  createdByStaff   Staff?                @relation(fields: [createdByStaffId], references: [staffId])
  planExercises    WorkoutPlanExercise[]

  @@index([category])
  @@index([muscleGroup])
  @@map("exercises")
}

model WorkoutPlan {
  planId          BigInt              @id @default(autoincrement()) @map("plan_id")
  creatorStaffId  BigInt?             @map("creator_staff_id")
  creatorMemberId BigInt?             @map("creator_member_id")
  creatorType     PlanCreatorType     @map("creator_type")
  name            String              @db.VarChar(100)
  description     String?
  status          WorkoutPlanStatus   @default(draft)
  deletedAt       DateTime?           @map("deleted_at") @db.Timestamp(6)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  assignments     MemberWorkoutPlan[]
  days            WorkoutPlanDay[]
  creatorMember   Member?             @relation("MemberCreatedPlans", fields: [creatorMemberId], references: [memberId])
  creatorStaff    Staff?              @relation(fields: [creatorStaffId], references: [staffId])

  @@index([creatorStaffId])
  @@index([creatorMemberId])
  @@map("workout_plans")
}

model WorkoutPlanDay {
  planDayId  BigInt                @id @default(autoincrement()) @map("plan_day_id")
  planId     BigInt                @map("plan_id")
  dayNumber  Int                   @map("day_number")
  name       String                @db.VarChar(100)
  notes      String?
  weekNumber Int                   @default(1) @map("week_number")
  dayOfWeek  Int                   @map("day_of_week")
  logs       WorkoutLog[]
  plan       WorkoutPlan           @relation(fields: [planId], references: [planId], onDelete: Cascade)
  exercises  WorkoutPlanExercise[]

  @@unique([planId, dayNumber])
  @@unique([planId, weekNumber, dayOfWeek])
  @@map("workout_plan_days")
}

model WorkoutPlanExercise {
  planExerciseId    BigInt          @id @default(autoincrement()) @map("plan_exercise_id")
  planDayId         BigInt          @map("plan_day_id")
  exerciseId        BigInt          @map("exercise_id")
  orderIndex        Int             @map("order_index")
  targetSets        Int             @map("target_sets")
  targetReps        Int?            @map("target_reps")
  targetDurationSec Int?            @map("target_duration_sec")
  targetWeightKg    Decimal?        @map("target_weight_kg") @db.Decimal(6, 2)
  restSeconds       Int?            @default(60) @map("rest_seconds")
  notes             String?
  logSets           WorkoutLogSet[]
  exercise          Exercise        @relation(fields: [exerciseId], references: [exerciseId])
  planDay           WorkoutPlanDay  @relation(fields: [planDayId], references: [planDayId], onDelete: Cascade)

  @@unique([planDayId, orderIndex])
  @@index([exerciseId])
  @@map("workout_plan_exercises")
}

model MemberWorkoutPlan {
  assignmentId      BigInt                  @id @default(autoincrement()) @map("assignment_id")
  memberId          BigInt                  @map("member_id")
  planId            BigInt                  @map("plan_id")
  assignedByStaffId BigInt?                 @map("assigned_by_staff_id")
  startDate         DateTime                @map("start_date") @db.Date
  status            WorkoutAssignmentStatus @default(active)
  endedAt           DateTime?               @map("ended_at") @db.Timestamp(6)
  notes             String?
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamp(6)
  assignedByStaff   Staff?                  @relation(fields: [assignedByStaffId], references: [staffId])
  member            Member                  @relation(fields: [memberId], references: [memberId])
  plan              WorkoutPlan             @relation(fields: [planId], references: [planId])
  logs              WorkoutLog[]

  @@index([memberId, status])
  @@index([planId])
  @@map("member_workout_plans")
}

model WorkoutLog {
  logId        BigInt            @id @default(autoincrement()) @map("log_id")
  memberId     BigInt            @map("member_id")
  assignmentId BigInt            @map("assignment_id")
  planDayId    BigInt            @map("plan_day_id")
  loggedAt     DateTime          @map("logged_at") @db.Timestamp(6)
  durationMin  Int?              @map("duration_min")
  notes        String?
  sets         WorkoutLogSet[]
  assignment   MemberWorkoutPlan @relation(fields: [assignmentId], references: [assignmentId])
  member       Member            @relation(fields: [memberId], references: [memberId])
  planDay      WorkoutPlanDay    @relation(fields: [planDayId], references: [planDayId])

  @@index([memberId, loggedAt(sort: Desc)])
  @@index([assignmentId])
  @@map("workout_logs")
}

model WorkoutLogSet {
  logSetId          BigInt              @id @default(autoincrement()) @map("log_set_id")
  logId             BigInt              @map("log_id")
  planExerciseId    BigInt              @map("plan_exercise_id")
  setNumber         Int                 @map("set_number")
  actualReps        Int?                @map("actual_reps")
  actualWeightKg    Decimal?            @map("actual_weight_kg") @db.Decimal(6, 2)
  actualDurationSec Int?                @map("actual_duration_sec")
  completed         Boolean             @default(true)
  log               WorkoutLog          @relation(fields: [logId], references: [logId], onDelete: Cascade)
  planExercise      WorkoutPlanExercise @relation(fields: [planExerciseId], references: [planExerciseId])

  @@unique([logId, planExerciseId, setNumber])
  @@index([planExerciseId])
  @@map("workout_log_sets")
}

model File {
  fileId      BigInt    @id @default(autoincrement()) @map("file_id")
  ownerUserId BigInt    @map("owner_user_id")
  fileType    FileType  @map("file_type")
  storagePath String    @map("storage_path") @db.VarChar(500)
  publicUrl   String?   @map("public_url") @db.VarChar(1000)
  mimeType    String    @map("mime_type") @db.VarChar(100)
  sizeBytes   BigInt    @map("size_bytes")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  owner       User      @relation("FileOwner", fields: [ownerUserId], references: [userId])
  avatarOf    User[]    @relation("UserAvatar")

  @@index([ownerUserId, fileType])
  @@map("files")
}


enum UserStatus {
  active
  locked
  pending_verification

  @@map("user_status")
}

enum PackageStatus {
  active
  inactive

  @@map("package_status")
}

enum PaymentMethod {
  cash
  bank_card
  ewallet

  @@map("payment_method")
}

enum PaymentStatus {
  success
  failed

  @@map("payment_status")
}

enum EquipmentStatus {
  active
  broken
  repairing
  retired

  @@map("equipment_status")
}

enum MaintenanceStatus {
  reported
  repairing
  resolved
  failed

  @@map("maintenance_status")
}

enum FeedbackType {
  staff
  equipment
  service

  @@map("feedback_type")
}

enum FeedbackSeverity {
  low
  medium
  high

  @@map("feedback_severity")
}

enum FeedbackStatus {
  open
  in_progress
  resolved
  rejected

  @@map("feedback_status")
}

enum AttendanceMethod {
  realtime
  manual
  qr

  @@map("attendance_method")
}

enum StaffShift {
  morning
  afternoon
  evening

  @@map("staff_shift")
}

enum SubscriptionStatus {
  pending
  active
  expired
  cancelled

  @@map("subscription_status")
}

enum TrainingSessionStatus {
  scheduled
  in_progress
  completed
  cancelled

  @@map("training_session_status")
}

enum FileType {
  avatar
  document
  equipment_doc

  @@map("file_type")
}

enum ExerciseCategory {
  strength
  cardio
  flexibility
  balance

  @@map("exercise_category")
}

enum WorkoutPlanStatus {
  draft
  active
  archived

  @@map("workout_plan_status")
}

enum WorkoutAssignmentStatus {
  active
  completed
  replaced

  @@map("workout_assignment_status")
}

enum PlanCreatorType {
  staff
  member

  @@map("plan_creator_type")
}
