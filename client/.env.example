# API base URL used by axios in src/services/api.ts.
# Leave empty (or omit the file) to use the Vite dev proxy and the default
# fallback "/api/v1" defined in src/services/api.ts.
VITE_API_URL=

# Local backend used by the Vite dev proxy. Vite waits for /health before
# accepting browser requests, avoiding ECONNREFUSED while Nest is starting.
API_PROXY_TARGET=http://127.0.0.1:3000

# LINE LIFF App ID for LINE Login (required for LINE login button on LoginPage)
VITE_LIFF_ID=your_liff_id_here
