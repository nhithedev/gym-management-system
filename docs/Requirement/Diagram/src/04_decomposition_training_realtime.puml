actor "Access Device\n(thẻ/QR/vân tay)" as AccessDevice

rectangle "Vận hành tập luyện Real-time" {
  usecase "UC05A\nPT lập lịch tập\ncho hội viên" as UC05A
  usecase "UC05B\nReal-time check-in\nqua Access Device" as UC05B
  usecase "UC06\nTheo dõi và Đánh giá tiến độ" as UC06
  usecase "UC07\nGửi phản hồi" as UC07
}

PT --> UC05A
PT --> UC06

Member --> UC05B
Member --> UC06
Member --> UC07

AccessDevice --> UC05B
